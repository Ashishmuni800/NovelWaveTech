@model Application.DTO.OtpRecordsDTO
@{
    Layout = "_OTPLayout";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Novel Wave Tech — OTP Verification</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

    <style>
        body {
            margin: 0;
            padding: 0;
            min-height: 80vh;
            background: linear-gradient(rgba(0,0,0,0.45), rgba(0,0,0,0.45)), url('@Url.Content("~/images/login-bg.png")');
            background-size: cover;
            /* background-position: center; */
            background-repeat: no-repeat;
            background-attachment: fixed;
        }

        .otp-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .otp-card {
            width: 100%;
            max-width: 500px;
            background: rgba(255,255,255,0.92);
            backdrop-filter: blur(12px);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0,0,0,0.25);
        }

        .brand-header {
            text-align: center;
            padding: 25px;
            background: linear-gradient(135deg,#0d6efd,#0a58ca);
            color: #fff;
        }

        .logo-text {
            font-size: 28px;
            font-weight: bold;
        }

            .logo-text .wave {
                color: #ffd54f;
            }

        .otp-body {
            padding: 30px;
        }

        .otp-icon i {
            font-size: 60px;
            color: #0d6efd;
        }

        .form-control {
            height: 50px;
            border-radius: 10px;
        }

        .btn-verify {
            height: 50px;
            border-radius: 10px;
            font-weight: 600;
        }

        .resend-link {
            text-decoration: none;
            font-weight: 600;
        }

            .resend-link:hover {
                text-decoration: underline;
            }

        @@media (max-width:576px) {
            .otp-card {
                margin: 10px;
            }

            .otp-body {
                padding: 20px;
            }
        }
    </style>
</head>

<body>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="toast position-fixed top-0 end-0 m-4" data-bs-delay="5000">
            <div class="toast-header bg-success text-white">
                <strong class="me-auto">Success</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body">
                @TempData["SuccessMessage"]
            </div>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="toast position-fixed top-0 end-0 m-4" role="alert"
             aria-live="assertive" aria-atomic="true"
             data-bs-delay="5000" data-bs-autohide="true" style="z-index: 1055;">
            <div class="toast-header bg-danger text-white">
                <strong class="me-auto">Error</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body">@TempData["ErrorMessage"]</div>
        </div>
    }
    @if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null){
    <div class="otp-wrapper">

        <div class="otp-card">

            <div class="brand-header">
                <div class="logo-text">
                    <span>Novel</span>
                    <span class="wave">Wave</span>
                    <span>Tech</span>
                </div>
                <p>Secure OTP Verification</p>
            </div>

            <div class="otp-body">

                <div class="text-center mb-3">
                    <i class="fa fa-shield-alt otp-icon"></i>
                </div>

                <p class="text-center text-muted">
                    Enter the 6-digit OTP sent to your email.
                </p>

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        @TempData["Error"]
                    </div>
                }

                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["Success"]
                    </div>
                }

                <form method="post" asp-action="VerifyOtp" asp-controller="Home">

                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Otp" class="form-label">OTP Code</label>

                        <input asp-for="Otp"
                               class="form-control text-center"
                               maxlength="6"
                               placeholder="Enter 6-digit OTP" required/>

                        <span asp-validation-for="Otp" class="text-danger"></span>
                    </div>

                    <div class="text-center mb-3">
                        <small class="text-danger">
                            OTP expires in <span id="countdown">03:00</span>
                        </small>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-verify">
                            <i class="fa fa-check-circle me-2"></i> Verify OTP
                        </button>
                    </div>

                    <div class="text-center">
                            <a href="/Home/OtpResend" id="resendOtp" class="resend-link">
                            Resend OTP
                        </a>
                    </div>

                </form>

            </div>
        </div>

        </div>
    }
    else
    {
        <script>
            window.location.href = '/Home/Login'
        </script>
    }
    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        let remainingSeconds = 180;

        function updateTimer() {
            let m = Math.floor(remainingSeconds / 60);
            let s = remainingSeconds % 60;

            document.getElementById("countdown").innerText =
                String(m).padStart(2, '0') + ":" + String(s).padStart(2, '0');

            if (remainingSeconds <= 0) {
                clearInterval(timer);
                document.getElementById("countdown").innerText = "Expired";
            }

            remainingSeconds--;
        }

        updateTimer();
        let timer = setInterval(updateTimer, 1000);

        // document.getElementById("resendOtp").addEventListener("click", function () {
        //     alert("Implement Resend OTP API here.");
        // });

        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll('.toast').forEach(t => new bootstrap.Toast(t).show());
        });
    </script>

</body>
</html>